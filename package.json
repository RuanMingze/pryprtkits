{
  "name": "pryprtkits",
  "version": "0.1.0-beta",
  "description": "PryprtKits - 前端通用工具箱库，包含 150+ 个实用工具函数",
  "main": "dist/pryprtkits.js",
  "module": "dist/pryprtkits.min.js",
  "browser": "dist/pryprtkits.js",
  "unpkg": "dist/pryprtkits.min.js",
  "jsdelivr": "dist/pryprtkits.min.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/pryprtkits.min.js",
      "require": "./dist/pryprtkits.js",
      "browser": "./dist/pryprtkits.min.js"
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --watch --mode development",
