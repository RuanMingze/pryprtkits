  },
  "keywords": [
    "utils",
    "tools",
    "file-converter",
    "encryption",
    "image-processing",
    "javascript",
    "frontend",
    "toolbox"
  ],
  "author": "RuanMingze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RuanMingze/pryprtkits.git"
  },
  "bugs": {
    "url": "https://github.com/RuanMingze/pryprtkits/issues"
   },
  "homepage": "",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "rimraf": "^5.0.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-bundle-analyzer": "^4.10.1",
    "terser-webpack-plugin": "^5.3.9"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "qrcode": "^1.5.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
